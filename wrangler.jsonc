{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "baptiste-fort-cv-api",
  "main": "worker.mjs",
  "compatibility_date": "2026-07-11",
  "workers_dev": true,
  "preview_urls": false,
  "secrets": {
    "required": ["OPENAI_API_KEY"]
  },
  "vars": {
    "ALLOWED_ORIGINS": "https://fortbaptiste.github.io",
    "OPENAI_TRANSCRIBE_MODEL": "gpt-4o-mini-transcribe"
  },
  "ratelimits": [
    {
      "name": "CHAT_GLOBAL_LIMITER",
      "namespace_id": "42001",
      "simple": {
        "limit": 30,
        "period": 60
      }
    },
    {
      "name": "CHAT_CLIENT_LIMITER",
      "namespace_id": "42002",
      "simple": {
        "limit": 8,
        "period": 60
      }
    },
    {
      "name": "AUDIO_GLOBAL_LIMITER",
      "namespace_id": "42003",
      "simple": {
        "limit": 8,
        "period": 60
      }
    },
    {
      "name": "AUDIO_CLIENT_LIMITER",
      "namespace_id": "42004",
      "simple": {
        "limit": 3,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true
  }
}
